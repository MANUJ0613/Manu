# Configuration du watcher Micromania (copié vers /etc/micromania-deals.env)

# >>> OBLIGATOIRE : ton webhook Discord <<<
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# (optionnel) Telegram à la place / en plus
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Boucle continue, illimitée (systemd relance si besoin)
LOOP_ENABLED=true
LOOP_MAX_SECONDS=0
LOOP_INTERVAL_SECONDS=30
FULL_CATALOG_EVERY_MINUTES=30

# Critères d'alerte
DISCOUNT_THRESHOLD=0.50
# Beaucoup de deals jeux/goodies sont à 39,99-49,99€ de réf -> seuil bas.
MIN_REFERENCE_PRICE=15
CONCURRENCY=24
# Inclure les deals en retrait magasin / rupture web (label dans l'alerte).
INCLUDE_UNAVAILABLE=true
# Détection des prix via les pages catégorie (fiable malgré DataDome).
# Le sitemap des fiches /p/ est servi "allégé" (sans prix) sur IP datacenter.
SCAN_SITEMAP=false

# État (dédup + frontière des packs) — persistant sur le VPS
STATE_FILE=/opt/micromania-deals/state/state.json
DEALS_LOG=/opt/micromania-deals/state/deals.log
