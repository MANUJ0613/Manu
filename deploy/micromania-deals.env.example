# Configuration du watcher Micromania (copié vers /etc/micromania-deals.env)

# >>> OBLIGATOIRE : webhook Discord par défaut (reçoit tout ce qui n'est pas
# routé ailleurs) <<<
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# (optionnel) ROUTAGE PAR % DE RÉDUCTION : un salon par fourchette de remise.
# Exemple 3 salons : <60% / 60-80% / >=80%
# DISCOUNT_TIERS=60,80
# DISCORD_WEBHOOK_DISCOUNT_TIERS=https://discord.com/api/webhooks/SALON_MOINS60,https://discord.com/api/webhooks/SALON_60A80,https://discord.com/api/webhooks/SALON_PLUS80
#
# (optionnel) ROUTAGE PAR TRANCHES DE PRIX : un salon par fourchette de prix.
# PRICE_TIERS = bornes croissantes ; DISCORD_WEBHOOK_TIERS = un webhook par
# tranche (même ordre, +1 que le nombre de bornes).
# Exemple 3 salons : <20€ / 20-80€ / >=80€
# PRICE_TIERS=20,80
# DISCORD_WEBHOOK_TIERS=https://discord.com/api/webhooks/SALON_MOINS20,https://discord.com/api/webhooks/SALON_20A80,https://discord.com/api/webhooks/SALON_PLUS80
#
# (alternative) routage par catégorie + salon pépites :
# DISCORD_WEBHOOK_JEUX=...
# DISCORD_WEBHOOK_COLLECTOR=...
# DISCORD_WEBHOOK_GOODIES=...
# DISCORD_WEBHOOK_PEPITES=...
# PEPITE_MIN=80

# (optionnel) Telegram à la place / en plus
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# >>> POUR LA VITESSE : proxy(s) RÉSIDENTIEL(s) (sinon l'IP datacenter du VPS
# est bannie par Incapsula).
#  • UN seul proxy :
# PROXY=http://user:pass@host:port
#  • PLUSIEURS proxies (recommandé : Webshare static residential, 20 IP) ->
#    la charge se répartit sur toutes les IP, le bot scanne ~20× plus vite SANS
#    taper plus fort sur une IP donnée (donc sans bannissement). Séparés par
#    virgule. Formats acceptés : "http://user:pass@host:port" OU "host:port:user:pass".
# PROXY_LIST=http://user:pass@195.40.128.56:6776,http://user:pass@192.53.70.90:5804,...
#    Avec un pool de proxies, tu peux remonter la concurrence (CONCURRENCY=12,
#    CATEGORY_CONCURRENCY=4) et baisser l'intervalle de boucle.
# Alternative gratuite : faire tourner le bot sur une IP résidentielle (chez toi).

# Boucle continue, illimitée (systemd relance si besoin)
LOOP_ENABLED=true
LOOP_MAX_SECONDS=0
# IMPORTANT : Incapsula (anti-bot) bannit les IP datacenter qui tapent trop.
# Cadence DOUCE obligatoire sur un VPS : passage rapide toutes les ~10 min,
# scan complet toutes les heures. (30s = bannissement assuré.)
LOOP_INTERVAL_SECONDS=600
FULL_CATALOG_EVERY_MINUTES=60

# Critères d'alerte
DISCOUNT_THRESHOLD=0.50
# Deals jusqu'aux accessoires à ~3€ de réf -> seuil très bas.
MIN_REFERENCE_PRICE=3
# Concurrence FAIBLE : trop de requêtes parallèles => blocage Incapsula.
CONCURRENCY=4
CATEGORY_CONCURRENCY=2
# Inclure les deals en retrait magasin / rupture web (label dans l'alerte).
INCLUDE_UNAVAILABLE=true
# NE PAS scanner les 13k fiches du sitemap sur le VPS (bannissement immédiat) :
# les fiches y sont de toute façon servies sans prix. On s'appuie sur les
# pages catégorie (qui, elles, contiennent les prix).
SCAN_SITEMAP=false

# État (dédup + frontière des packs) — persistant sur le VPS
STATE_FILE=/opt/micromania-deals/state/state.json
DEALS_LOG=/opt/micromania-deals/state/deals.log
