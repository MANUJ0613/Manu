# Configuration de l'analyseur de demande Vinted
# (copié vers /etc/vinted-demand.env si tu le lances en service systemd)

# Recherches à analyser. Soit ici (séparées par des virgules), soit dans
# watchlist.txt (une par ligne). VINTED_QUERIES a la priorité.
# VINTED_QUERIES=nike air max,jordan 1,stanley cup,labubu

# Domaine Vinted (vinted.fr, vinted.de, vinted.com…)
VINTED_DOMAIN=www.vinted.fr

# Profondeur de scan : pages de 96 articles par recherche.
MAX_PAGES=3

# --- VUES (facultatif) ---
# Les vues ne sont renvoyées qu'à un compte CONNECTÉ. Pour les obtenir :
#  1) connecte-toi sur vinted.fr dans ton navigateur ;
#  2) ouvre les outils dev (F12) -> Réseau -> une requête vers /api/v2/... ;
#  3) copie la valeur ENTIÈRE de l'en-tête "Cookie" et colle-la ici ;
#  4) mets FETCH_VIEWS=true.
# Sans ça, le classement se fait sur les FAVORIS (largement suffisant).
# FETCH_VIEWS=true
# VINTED_COOKIE=access_token_web=...; _vinted_fr_session=...; ...
# TOP_VIEWS=20

# --- Notifications (facultatif) ---
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Proxy résidentiel (recommandé sur un VPS, IP datacenter = DataDome) ---
# PROXY=http://user:pass@host:port

# --- Mode boucle (service systemd continu) ---
# LOOP_ENABLED=true
# LOOP_INTERVAL_SECONDS=3600   # une analyse par heure
# LOOP_MAX_SECONDS=0           # 0 = illimité

# Concurrence douce (anti-ban)
CONCURRENCY=4

# Sorties
REPORT_JSON=state/vinted_report.json
REPORT_CSV=state/vinted_report.csv
