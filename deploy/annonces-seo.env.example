# Configuration de l'outil de revente SEO (copié vers /etc/annonces-seo.env)
# ============================================================================

# --- API Claude (génération titre + description) ----------------------------
# >>> OBLIGATOIRE pour la génération d'annonce <<<
# Clé sur https://console.anthropic.com  (ou profil `ant auth login`).
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Modèle (par défaut claude-opus-4-8). Pour réduire le coût : claude-sonnet-5 ou claude-haiku-4-5
# ANNONCES_MODEL=claude-opus-4-8

# --- DataForSEO (vrais volumes de mots-clés Google) -------------------------
# Compte sur https://dataforseo.com  (login = e-mail, password = clé API).
# Sans ça, l'app marche mais sans les volumes réels.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# DATAFORSEO_LOCATION=France
# DATAFORSEO_LANGUAGE=French

# --- ntfy (alertes push de republication) -----------------------------------
# Choisis un nom de topic SECRET et abonne-toi dessus depuis l'appli ntfy.
NTFY_TOPIC=revente-secret-a-changer
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=                       # si ton topic est protégé

# --- Seuils de republication 🟢🟠🔴 (en heures) ------------------------------
# Utilisés si une annonce n'a pas de cadence propre (anciennes annonces).
# REPUB_WARN_HEURES=72              # au-delà -> 🟠 orange (3 jours)
# REPUB_CRIT_HEURES=168             # au-delà -> 🔴 rouge  (7 jours)

# --- Cadence de republication par plateforme (en jours) ---------------------
# Chaque nouvelle annonce reçoit cette cadence selon sa plateforme ; les seuils
# 🟠/🔴 s'y alignent (orange 2 j avant l'échéance). Modifiable par annonce.
# REPUB_CADENCE_VINTED=8            # Vinted : fraîcheur, 7-10 j
# REPUB_CADENCE_LEBONCOIN=12        # Leboncoin : annonce vit 60 j, 10-14 j
# RELIST_MIN_HEURES=24             # garde-fou anti-spam entre deux reposts

# --- Frais plateformes (surcharge si les règles changent) -------------------
# Vinted : 0 frais vendeur par défaut. Leboncoin : commission si paiement sécurisé.
# LBC_COMMISSION_PCT=0
# LBC_COMMISSION_FIXE=0
# VINTED_PROTECTION_PCT=5           # payée par l'ACHETEUR (informatif)
# VINTED_PROTECTION_FIXE=0.70

# --- Divers -----------------------------------------------------------------
# URL publique de l'appli (mise dans les notifs ntfy, cliquable).
# ANNONCES_PUBLIC_URL=https://revente.mondomaine.fr
# Intervalle de vérification des alertes (secondes)
# ANNONCES_SCHED_INTERVAL=300
# Inclure les 🟠 orange dans les alertes (sinon seulement 🔴 rouge)
# ALERTE_INCLURE_ORANGE=true
# Emplacement de la base SQLite
# ANNONCES_DB=/opt/annonces-seo/state/annonces.db
# Port (si lancé sans gunicorn)
# PORT=8000
