# ---------------------------------------------------------------------------
# Autobuy — configuration (copie vers /etc/autobuy.env, chmod 600).
# NE COMMITTE JAMAIS ce fichier rempli : il contient tes accès.
# ---------------------------------------------------------------------------

# --- Sécurité / garde-fous ---------------------------------------------------
AUTOBUY_DRY_RUN=true               # true = aucune commande réelle (commence ainsi !)
AUTOBUY_DAILY_SPEND_CAP=300        # plafond de dépense par jour (€)
AUTOBUY_ENABLED=true

# --- Cadence (anti-ban) ------------------------------------------------------
AUTOBUY_WATCHLIST_INTERVAL=10      # s entre deux passages de la watchlist
AUTOBUY_COLLECTOR_INTERVAL=300     # s entre deux scans des rayons collector
AUTOBUY_MIN_INTERVAL=1.5           # délai plancher global par domaine
AUTOBUY_CONCURRENCY=6
# AUTOBUY_PROXY=http://user:pass@ip:port   # proxy résidentiel conseillé si bans

# --- Cibles ------------------------------------------------------------------
AUTOBUY_WATCHLIST=/opt/autobuy/autobuy_watchlist.json
AUTOBUY_STATE_FILE=/opt/autobuy/state/autobuy_state.json
AUTOBUY_COLLECTOR=true

# --- Sites activés -----------------------------------------------------------
AUTOBUY_SITE_FUNKO=true
AUTOBUY_SITE_MICROMANIA=true
AUTOBUY_SITE_FNAC=true

FUNKO_BASE=https://funko.com/fr
FUNKO_COLLECTIONS=nouveautes,editions-limitees,exclusivites
MICROMANIA_BASE=https://www.micromania.fr
# MICROMANIA_CATEGORIES=https://www.micromania.fr/collector-c123.html,...
FNAC_BASE=https://www.fnac.com
# FNAC_CATEGORIES=https://www.fnac.com/...

# --- Alertes -----------------------------------------------------------------
# ntfy (push tel) : installe l'appli ntfy, abonne-toi à ton topic secret.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=mets-un-topic-secret-a-toi
# NTFY_TOKEN=                        # si topic protégé
AUTOBUY_DISCORD_WEBHOOK=            # webhook Discord dédié (sinon DISCORD_WEBHOOK_URL)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Auto-checkout piloté (facultatif) --------------------------------------
# Nécessite Playwright + une session déjà connectée exportée en storageState JSON
# (voir README : tu te connectes UNE fois, tu enregistres l'état). Aucune carte
# n'est stockée : on utilise ta carte déjà enregistrée sur le compte marchand.
AUTOBUY_PLAYWRIGHT=false
AUTOBUY_HEADLESS=true
# FUNKO_STORAGE=/opt/autobuy/secrets/funko.storage.json
# MICROMANIA_STORAGE=/opt/autobuy/secrets/micromania.storage.json
# FNAC_STORAGE=/opt/autobuy/secrets/fnac.storage.json
